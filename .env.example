# Polymarket Arbitrage Detector Configuration
# Copy this file to .env and customize for your environment

# API Configuration
ARBITRAGE_POLYMARKET_API_URL=https://gamma-api.polymarket.com
ARBITRAGE_API_TIMEOUT_SECONDS=30.0
ARBITRAGE_API_MAX_CONNECTIONS=100

# Rate Limiting
ARBITRAGE_RATE_LIMIT_REQUESTS_PER_SECOND=10.0
ARBITRAGE_RATE_LIMIT_BURST=20

# Resilience
ARBITRAGE_RETRY_MAX_ATTEMPTS=3
ARBITRAGE_RETRY_BASE_DELAY_SECONDS=1.0
ARBITRAGE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ARBITRAGE_CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECONDS=60.0

# Strategy
ARBITRAGE_ARBITRAGE_THRESHOLD=0.99
ARBITRAGE_MIN_LIQUIDITY_USD=1000
ARBITRAGE_MIN_VOLUME_USD=10000

# Execution
ARBITRAGE_PAPER_TRADING_ENABLED=true
ARBITRAGE_INITIAL_CAPITAL_USD=10000
ARBITRAGE_MAX_POSITION_SIZE_USD=100

# Market Filters (comma-separated)
ARBITRAGE_MARKET_CATEGORIES=politics,crypto

# Monitoring
ARBITRAGE_LOG_LEVEL=INFO
ARBITRAGE_JSON_LOGS=true
ARBITRAGE_METRICS_PORT=9090

# Polling
ARBITRAGE_POLL_INTERVAL_SECONDS=60.0
