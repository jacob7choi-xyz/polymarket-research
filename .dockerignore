venv/
env/
.venv

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# Logs
logs/
*.log

# Environment
.env
.env.local

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml

# Monitoring (already in image)
monitoring/

# OS
.DS_Store
Thumbs.db
